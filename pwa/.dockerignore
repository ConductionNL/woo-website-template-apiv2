# Build context = pwa/ (zie root docker-compose.yml)
# Houden we strak: alles wat niet bijdraagt aan de build of het serveren
# blijft buiten het image.

# Dependency / build artefacten
node_modules
.cache
public
.gatsby-cache
.parcel-cache

# Test / coverage
coverage
.nyc_output

# Lint / format caches
.eslintcache
.prettiercache
.stylelintcache

# OS / editor
.DS_Store
Thumbs.db
.idea
.vscode
*.swp
*.swo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Lokale env (build-args komen via compose, niet via .env-copy)
.env
.env.*
!.env.example

# Docker- en CI-bestanden niet nodig binnen image
Dockerfile
.dockerignore
docker-compose*.yml

# Documentatie / VCS
README.md
*.md
.git
.gitignore
.gitattributes

# Patches mogen er WEL in (patch-package gebruikt ze tijdens npm ci)
!patches
